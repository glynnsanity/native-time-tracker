# Supabase Configuration
# Create project at https://supabase.com
# Find these values in Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth Configuration
# Create credentials at https://console.cloud.google.com
# Create OAuth Client IDs for each platform
EXPO_PUBLIC_GOOGLE_CLIENT_ID_EXPO=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=

# RevenueCat Configuration
# Create account at https://www.revenuecat.com
# Find API key in Project Settings > API Keys
EXPO_PUBLIC_REVENUECAT_API_KEY=
